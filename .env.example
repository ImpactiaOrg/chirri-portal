# Django
# Si no seteás DJANGO_SECRET_KEY en dev, base.py genera un token_urlsafe(64)
# random por run (rotás sesiones/JWT al reiniciar — aceptable en dev).
# En prod ES obligatoria: production.py hace fail-fast si falta.
# DJANGO_SECRET_KEY=
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# En prod: agregar el host público, p.ej. chirri.impactia.ai
# DJANGO_ALLOWED_HOSTS=chirri.impactia.ai
# CORS_ALLOWED_ORIGINS=https://chirri.impactia.ai
# CSRF_TRUSTED_ORIGINS=https://chirri.impactia.ai

# Postgres
POSTGRES_DB=chirri
POSTGRES_USER=chirri
POSTGRES_PASSWORD=chirri
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Superuser bootstrap (entrypoint)
DJANGO_SUPERUSER_EMAIL=admin@chirri.local
DJANGO_SUPERUSER_PASSWORD=admin

# Frontend
BACKEND_INTERNAL_URL=http://backend:8000
NEXT_PUBLIC_APP_NAME=Chirri Portal
APP_URL=http://localhost:3000

# --- Cloudflare R2 (unset locally = filesystem storage) ---
# USE_R2=1
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT_URL=
# R2_BUCKET_NAME=chirri-media
# R2_PUBLIC_URL=
